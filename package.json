{
    "name": "jazari",
    "displayName": "Jazari",
    "description": "Dark and light VS Code theme. Teal accent, rounded floating panels, backdrop blur, zero noise. Named after Al-Jazari.",
    "version": "1.0.0",
    "publisher": "aalasolutions",
    "icon": "assets/icon.png",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/aalasolutions/vscode-jazari"
    },
    "homepage": "https://github.com/aalasolutions/vscode-jazari#readme",
    "bugs": {
        "url": "https://github.com/aalasolutions/vscode-jazari/issues"
    },
    "engines": {
        "vscode": "^1.89.0"
    },
    "categories": [
        "Themes"
    ],
    "keywords": [
        "vscode",
        "vscode-theme",
        "dark",
        "light",
        "theme",
        "teal",
        "developer",
        "jazari",
        "clean",
        "minimal",
        "modern",
        "rounded",
        "glass",
        "syntax-highlighting",
        "dark-theme",
        "light-theme"
    ],
    "galleryBanner": {
        "color": "#0F1114",
        "theme": "dark"
    },
    "main": "./out/extension.js",
    "activationEvents": [
        "onStartupFinished"
    ],
    "contributes": {
        "themes": [
            {
                "label": "Jazari Dark",
                "uiTheme": "vs-dark",
                "path": "./themes/jazari-dark.json"
            },
            {
                "label": "Jazari Light",
                "uiTheme": "vs",
                "path": "./themes/jazari-light.json"
            }
        ],
        "commands": [
            {
                "command": "jazari.removeCssImport",
                "title": "Remove CSS Customizations",
                "category": "Jazari"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "tsc -p ./",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.89.0",
        "typescript": "^5.4.0"
    }
}
